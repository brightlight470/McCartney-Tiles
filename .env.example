# McCartney Tiles — environment variables (example).
# Copy to .env (root) and apps/*/.env.local as needed. Never commit real secrets.

# --- Database (Postgres) ---
# Payload reads DATABASE_URI; app code may read DATABASE_URL. Keep them equal.
DATABASE_URI=postgresql://mccartney:mccartney@localhost:5432/mccartney
DATABASE_URL=postgresql://mccartney:mccartney@localhost:5432/mccartney

# --- Payload CMS ---
PAYLOAD_SECRET=change-me-in-local-only-never-commit
# Public URL of the CMS/admin (used for generated links)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
# Where the web app reads catalogue/content from (Payload REST API base)
CMS_URL=http://localhost:3001

# --- Search (Meilisearch) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=masterKey-local-dev-only
MEILISEARCH_INDEX=products

# --- Object storage / image CDN (S3-class) ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
IMAGE_CDN_BASE=

# --- Auth (Auth.js) ---
NEXTAUTH_SECRET=change-me-in-local-only
NEXTAUTH_URL=http://localhost:3000

# --- Lead Connect (GoHighLevel — whitelabelled). Supplied at the CRM integration gate (task #16). ---
# Until supplied, CRM_DRIVER=mock keeps the app building/testing against the mock client.
CRM_DRIVER=mock
GHL_API_TOKEN=
GHL_LOCATION_ID=

# --- Roomvo visualiser (Phase 3 — feature-flagged off until keyed) ---
ROOMVO_KEY=
NEXT_PUBLIC_ROOMVO_ENABLED=false

# --- Geolocation ---
GEO_PROVIDER_KEY=
# Default region when geo cannot be resolved (IE | NI | ROW)
NEXT_PUBLIC_DEFAULT_REGION=NI

# --- Monitoring ---
SENTRY_DSN=

# --- Feature flags ---
NEXT_PUBLIC_ECOMMERCE_ENABLED=false   # Phase 2
